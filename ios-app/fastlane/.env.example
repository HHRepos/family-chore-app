# Copy this file to fastlane/.env and fill in your values.
# fastlane/.env is gitignored — never commit it.
#
# Get these from https://appstoreconnect.apple.com → Users and Access →
# Integrations → App Store Connect API.

ASC_KEY_ID=YOUR_10_CHAR_KEY_ID
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000
ASC_KEY_PATH=/Users/YOU/.appstoreconnect/private_keys/AuthKey_YOUR_KEY_ID.p8
